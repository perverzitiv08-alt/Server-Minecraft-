<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<title>Helkor Server</title>

<link href="https://fonts.cdnfonts.com/css/minecraftia" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Minecraftia', sans-serif;
  background: url('https://i.imgur.com/t6YV8bK.jpg') no-repeat center/cover;
  color: white;
}

/* tmavý overlay */
.overlay {
  background: rgba(0,0,0,0.7);
  min-height: 100vh;
  padding: 20px;
  text-align: center;
}

/* nadpis */
h1 {
  font-size: 50px;
  text-shadow: 5px 5px black;
  animation: glow 2s infinite alternate;
}

@keyframes glow {
  from { text-shadow: 5px 5px black; }
  to { text-shadow: 5px 5px black, 0 0 20px lime; }
}

/* panely */
.panel {
  background: rgba(80,60,30,0.9);
  border: 5px solid #2b1a0d;
  box-shadow: inset 0 0 15px black;
  padding: 20px;
  margin: 20px auto;
  width: 85%;
}

/* tlačítka */
.mc-btn {
  padding: 15px 30px;
  margin: 10px;
  background: linear-gradient(#8c5a2b, #4e2d12);
  border: 4px solid #2b1a0d;
  color: white;
  cursor: pointer;
  transition: 0.2s;
}

.mc-btn:hover {
  transform: scale(1.1);
}

.blue { background: linear-gradient(#5b6ee1, #2d3f9f); }
.green { background: linear-gradient(#5dbb63, #2e7d32); }

/* inputy */
input, textarea {
  width: 80%;
  padding: 10px;
  margin: 5px;
  background: #2b1a0d;
  border: 2px solid black;
  color: white;
}

/* layout */
.row {
  display: flex;
  flex-wrap: wrap;
}

.col {
  flex: 1;
  min-width: 300px;
  padding: 10px;
}

/* dynmap */
iframe {
  width: 100%;
  height: 400px;
  border: 3px solid black;
}
</style>
</head>

<body>

<div class="overlay">

<h1>⛏️ HELKOR SERVER ⛏️</h1>

<div class="panel">
<h2 id="players">Načítám hráče...</h2>
<h3>IP: cz1.helkor.eu:41004</h3>

<button class="mc-btn" onclick="copyIP()">📋 Kopírovat IP</button>
<button class="mc-btn blue" onclick="window.open('https://discord.gg/t4Caja7V7')">💬 Discord</button>
</div>

<div class="panel">
<h2>📋 Přihláška</h2>

<form action="https://formspree.io/f/tvojeID" method="POST">
<input type="text" name="nick" placeholder="Nick" required><br>
<input type="text" name="pozice" placeholder="Pozice" required><br>
<textarea name="text" placeholder="Proč chceš do týmu?" required></textarea><br>
<button class="mc-btn green">Odeslat</button>
</form>
</div>

<div class="panel row">

<div class="col">
<h2>🗺️ Dynmapa</h2>
<iframe src="http://cz1.helkor.eu:41185"></iframe>
</div>

<div class="col">
<h2>📰 Novinky</h2>
<p>🔥 Server spuštěn</p>
<p>⚔️ Eventy brzy</p>
<p>👑 Nabíráme tým</p>
</div>

</div>

<div class="panel">
<h2>👤 Účet</h2>

<input type="email" id="email" placeholder="Email"><br>
<input type="password" id="password" placeholder="Heslo"><br>

<button class="mc-btn green" onclick="register()">Registrace</button>
<button class="mc-btn blue" onclick="login()">Přihlášení</button>

<p id="user"></p>
</div>

</div>

<script>
// hráči
fetch("https://api.mcsrvstat.us/2/cz1.helkor.eu:41004")
.then(res => res.json())
.then(data => {
  document.getElementById("players").innerText =
    "Hráči Online: " + data.players.online + " / " + data.players.max;
});

// copy IP
function copyIP() {
  navigator.clipboard.writeText("cz1.helkor.eu:41004");
  alert("IP zkopírována!");
}
</script>

</body>
</html>