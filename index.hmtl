<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<title>Helkor Server</title>

<link href="https://fonts.cdnfonts.com/css/minecraftia" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Minecraftia', sans-serif;
  background: url('https://i.imgur.com/VYpYBqS.jpg') no-repeat center/cover;
  color: white;
}

/* overlay */
.overlay {
  background: rgba(0,0,0,0.6);
  min-height: 100vh;
  padding: 20px;
  text-align: center;
}

/* title */
h1 {
  font-size: 50px;
  text-shadow: 4px 4px black;
}

/* wooden panel */
.panel {
  background: url('https://i.imgur.com/6b7R6cD.png');
  background-size: cover;
  border: 5px solid #3b2a18;
  padding: 20px;
  margin: 20px auto;
  width: 85%;
  box-shadow: 0 0 20px black;
}

/* buttons */
.mc-btn {
  padding: 15px 30px;
  margin: 10px;
  border: none;
  font-family: 'Minecraftia';
  cursor: pointer;
  font-size: 14px;
  color: white;
  background: linear-gradient(#a66b2d, #6b3f1d);
  border: 3px solid #3b2a18;
  box-shadow: inset -3px -3px #3b2a18, inset 3px 3px #d8a35d;
}

.mc-btn:hover {
  filter: brightness(1.2);
}

.blue {
  background: linear-gradient(#5b6ee1, #2d3f9f);
}

.green {
  background: linear-gradient(#5dbb63, #2e7d32);
}

/* layout */
.row {
  display: flex;
  flex-wrap: wrap;
}

.col {
  flex: 1;
  min-width: 300px;
  padding: 10px;
}

/* inputs */
input, textarea {
  width: 80%;
  padding: 10px;
  margin: 5px;
  background: #2b1a0d;
  border: 2px solid black;
  color: white;
}

/* dynmap preview */
.map-preview {
  width: 100%;
  border: 4px solid black;
}
</style>
</head>

<body>

<div class="overlay">

<h1>⛏️ HELKOR SERVER ⛏️</h1>

<div class="panel">
<h2 id="players">Načítám hráče...</h2>
<h3>IP: cz1.helkor.eu:41004</h3>

<button class="mc-btn" onclick="copyIP()">📋 Kopírovat IP</button>
<button class="mc-btn blue" onclick="window.open('https://discord.gg/t4Caja7V7')">💬 Discord</button>
</div>

<div class="panel">
<h2>📋 Přihláška do týmu</h2>

<form action="https://formspree.io/f/tvojeID" method="POST">
<input type="text" name="nick" placeholder="Nick" required><br>
<input type="text" name="pozice" placeholder="Builder/Admin/Helper" required><br>
<textarea name="text" placeholder="Proč chceš do týmu?" required></textarea><br>
<button class="mc-btn green">Odeslat</button>
</form>
</div>

<div class="panel row">

<div class="col">
<h2>🗺️ Dynmapa serveru</h2>

<img src="https://i.imgur.com/6z9Yb6X.png" class="map-preview">

<br>

<button class="mc-btn" onclick="window.open('http://cz1.helkor.eu:41185')">
Zobrazit celou mapu
</button>
</div>

<div class="col">
<h2>📰 Novinky</h2>
<p>📅 Nový event tuto sobotu!</p>
<p>⚙️ Nové updaty přidány</p>
<p>🛠️ Opravy serveru</p>

<button class="mc-btn">Více novinek</button>
</div>

</div>

<div class="panel">
<h2>👤 Účet</h2>

<input type="email" placeholder="Email"><br>
<input type="password" placeholder="Heslo"><br>

<button class="mc-btn green">Registrace</button>
<button class="mc-btn blue">Přihlášení</button>
</div>

</div>

<script>
// hráči
fetch("https://api.mcsrvstat.us/2/cz1.helkor.eu:41004")
.then(res => res.json())
.then(data => {
  document.getElementById("players").innerText =
    "Hráči Online: " + data.players.online + " / " + data.players.max;
});

// copy IP
function copyIP() {
  navigator.clipboard.writeText("cz1.helkor.eu:41004");
  alert("IP zkopírována!");
}
</script>

</body>
</html>